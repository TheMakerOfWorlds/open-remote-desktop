# Open Remote Desktop local Mac config.
# Copy to:
#   ~/Library/Application Support/Open Remote Desktop/config/local.conf
#
# This file is intentionally not committed when renamed to local.conf.

# Display name used in notifications.
REMOTE_NAME="Remote Mac"

# SSH host alias, hostname, or IP for the remote Mac.
# Recommended: create a Host entry in ~/.ssh/config and put that alias here.
REMOTE_SSH_ALIAS="remote-mac"

# Hostname or IP for macOS Screen Sharing. This must be reachable by the
# Screen Sharing app; SSH config aliases are not used unless they are also DNS.
REMOTE_VNC_HOST="remote-mac"
REMOTE_VNC_PORT=5900

# macOS account name on the remote Mac, used in the Screen Sharing URL.
REMOTE_USER="admin"

# Default is direct Screen Sharing with no SSH tunnel. Set USE_SSH_TUNNEL=1
# only when you explicitly want Screen Sharing carried through SSH.
USE_SSH_TUNNEL=0

# Local forwarded VNC port used only when USE_SSH_TUNNEL=1.
LOCAL_PORT=5902

# Optional: show a notification when opening the desktop session.
SHOW_OPEN_NOTIFICATION=0

# Where dropped local files should land on the remote Mac.
REMOTE_DROP_DIR="Downloads"

# Faster for most first-time LAN/Tailscale copies. Set to 0 to let rsync use
# delta updates for repeatedly changing large files over slower links.
RSYNC_WHOLE_FILE=1

# Enable the microphone relay. Set to 0 to use remote desktop only.
ENABLE_MIC=1

# Optional remote mic settings.
REMOTE_RECEIVER="bin/receive-local-mic-to-blackhole"
LOCAL_MIC_NAME="MacBook Pro Microphone"
LOCAL_GAIN_DB="18"
SOURCE_MODE="ffmpeg"

# Optional tool paths. Homebrew installs are usually here on Apple Silicon.
FFMPEG="/opt/homebrew/bin/ffmpeg"
SOX="/opt/homebrew/bin/rec"
