#!/bin/zsh
emulate -LR zsh
set -euo pipefail

APP_NAME="Open Remote Desktop"
APP_SUPPORT_DIR="${OPEN_REMOTE_SUPPORT_DIR:-$HOME/Library/Application Support/Open Remote Desktop}"
CONFIG_DIR="${OPEN_REMOTE_CONFIG_DIR:-$APP_SUPPORT_DIR/config}"
CONFIG_FILE="${OPEN_REMOTE_CONFIG_FILE:-$CONFIG_DIR/local.conf}"
LOG_DIR="${OPEN_REMOTE_LOG_DIR:-$HOME/Library/Logs/Open Remote Desktop}"
MIC_LOG="$LOG_DIR/remote-mic.log"
TRANSFER_LOG="$LOG_DIR/file-transfer.log"
LAUNCH_LOG="$LOG_DIR/launcher.log"
SCRIPT_DIR="${0:A:h}"
PROGRESS_VIEWER="${SCRIPT_DIR:h}/Resources/transfer-progress.jxa"

[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

REMOTE_NAME="${REMOTE_NAME:-Remote Mac}"
REMOTE_SSH_ALIAS="${REMOTE_SSH_ALIAS:-}"
REMOTE_USER="${REMOTE_USER:-}"
USE_SSH_TUNNEL="${USE_SSH_TUNNEL:-0}"
SHOW_OPEN_NOTIFICATION="${SHOW_OPEN_NOTIFICATION:-0}"
REMOTE_VNC_HOST="${REMOTE_VNC_HOST:-$REMOTE_SSH_ALIAS}"
REMOTE_VNC_PORT="${REMOTE_VNC_PORT:-5900}"
LOCAL_PORT="${LOCAL_PORT:-5902}"
LOCAL_VNC_PORT="${LOCAL_VNC_PORT:-}"
if [[ -z "$LOCAL_VNC_PORT" ]]; then
  if [[ "$USE_SSH_TUNNEL" == "1" ]]; then
    LOCAL_VNC_PORT="$LOCAL_PORT"
  else
    LOCAL_VNC_PORT="$REMOTE_VNC_PORT"
  fi
fi
VNC_MATCH_HOST="${VNC_MATCH_HOST:-}"
if [[ -z "$VNC_MATCH_HOST" && "$USE_SSH_TUNNEL" != "1" ]]; then
  VNC_MATCH_HOST="$REMOTE_VNC_HOST"
fi
CONTROL_SOCKET="${CONTROL_SOCKET:-$HOME/.ssh/cm-open-remote-desktop}"
VNC_OPTIONS="${VNC_OPTIONS:-quality=adaptive&scalingMode=scaled&autoClipboard=1}"
MIC_CONTROL="${MIC_CONTROL:-$HOME/bin/remote-mic-control}"
REMOTE_DROP_DIR="${REMOTE_DROP_DIR:-Downloads}"
ENABLE_MIC="${ENABLE_MIC:-1}"
RSYNC_WHOLE_FILE="${RSYNC_WHOLE_FILE:-1}"
TUNNEL_OWNER=0
MIC_WAS_RUNNING=0
PROGRESS_VIEWER_PID=""
CANCEL_MONITOR_PID=""
TUNNEL_PID=""

SSH_OPTS=(
  -o BatchMode=yes
  -o ConnectTimeout=8
  -o ServerAliveInterval=15
  -o ServerAliveCountMax=2
  -o TCPKeepAlive=yes
  -o Compression=no
  -o IPQoS=none
  -o LogLevel=ERROR
  -o StrictHostKeyChecking=yes
  -o "UserKnownHostsFile=$HOME/.ssh/known_hosts"
)
[[ -n "${SSH_IDENTITY_FILE:-}" ]] && SSH_OPTS+=(-o "IdentityFile=${SSH_IDENTITY_FILE}" -o IdentitiesOnly=yes)

umask 077
/bin/mkdir -p "$LOG_DIR"
: >> "$MIC_LOG"
: >> "$TRANSFER_LOG"
: >> "$LAUNCH_LOG"
/bin/chmod 700 "$LOG_DIR" >/dev/null 2>&1 || true
/bin/chmod 600 "$MIC_LOG" "$TRANSFER_LOG" "$LAUNCH_LOG" >/dev/null 2>&1 || true

timestamp() {
  /bin/date "+%Y-%m-%d %H:%M:%S"
}

transfer_log() {
  printf '[%s] %s\n' "$(timestamp)" "$*" >> "$TRANSFER_LOG"
}

launcher_log() {
  printf '[%s] pid=%s %s\n' "$(timestamp)" "$$" "$*" >> "$LAUNCH_LOG"
}

notify_user() {
  local title="$1" message="$2"
  /usr/bin/osascript - "$title" "$message" <<'APPLESCRIPT' >/dev/null 2>&1 || true
on run argv
	display notification (item 2 of argv) with title (item 1 of argv)
end run
APPLESCRIPT
}

alert_user() {
  local title="$1" message="$2"
  /usr/bin/osascript - "$title" "$message" <<'APPLESCRIPT' >/dev/null 2>&1 || true
on run argv
	display alert (item 1 of argv) message (item 2 of argv) as warning
end run
APPLESCRIPT
}

validate_config() {
  if [[ -z "$REMOTE_SSH_ALIAS" || -z "$REMOTE_USER" ]]; then
    alert_user "$APP_NAME needs setup" "Edit ${CONFIG_FILE} and set REMOTE_SSH_ALIAS and REMOTE_USER before using the app."
    exit 64
  fi
  if [[ -z "$REMOTE_VNC_HOST" ]]; then
    alert_user "$APP_NAME needs setup" "Edit ${CONFIG_FILE} and set REMOTE_VNC_HOST to the remote Mac hostname or IP used by Screen Sharing."
    exit 64
  fi
  if [[ "$REMOTE_SSH_ALIAS" == -* || "$REMOTE_USER" == -* || "$REMOTE_VNC_HOST" == -* || "$REMOTE_DROP_DIR" == -* ]]; then
    alert_user "$APP_NAME config error" "Remote alias, user, VNC host, and drop directory must not begin with '-'."
    exit 64
  fi
  if [[ "$USE_SSH_TUNNEL" != "0" && "$USE_SSH_TUNNEL" != "1" ]]; then
    alert_user "$APP_NAME config error" "USE_SSH_TUNNEL must be 0 or 1."
    exit 64
  fi
  if [[ "$REMOTE_VNC_PORT" != <-> || "$LOCAL_PORT" != <-> || "$LOCAL_VNC_PORT" != <-> ]]; then
    alert_user "$APP_NAME config error" "VNC ports must be numeric."
    exit 64
  fi
}

progress_write() {
  local state_file="$1" state="$2" percent="$3" title="$4" detail="${5:-}" tmp_file
  tmp_file="$(/usr/bin/mktemp "${state_file}.XXXXXX")" || return 1
  printf '%s\n%s\n%s\n%s\n' "$state" "$percent" "$title" "$detail" > "$tmp_file"
  /bin/mv -f "$tmp_file" "$state_file"
}

start_progress_viewer() {
  local state_file="$1" title="$2" cancel_file="$3" slot="$(( $$ % 4 ))"
  PROGRESS_VIEWER_PID=""
  if [[ -f "$PROGRESS_VIEWER" ]]; then
    /usr/bin/osascript -l JavaScript "$PROGRESS_VIEWER" "$state_file" "$title" "$slot" "$cancel_file" >/dev/null 2>&1 &
    PROGRESS_VIEWER_PID="$!"
  fi
}

cleanup_progress_state_later() {
  local state_file="$1" cancel_file="$2"
  ( /bin/sleep 3; /bin/rm -f "$state_file" "$cancel_file" >/dev/null 2>&1 || true ) >/dev/null 2>&1 &
}

update_rsync_progress() {
  local state_file="$1" cancel_file="$2" item_count="$3" line percent
  while IFS= read -r line; do
    [[ -f "$cancel_file" ]] && return 130
    [[ -n "$line" ]] || continue
    printf '%s\n' "$line" >> "$TRANSFER_LOG"
    percent="$(printf '%s\n' "$line" | /usr/bin/sed -nE 's/.*[[:space:]]([0-9]{1,3})%.*/\1/p' | /usr/bin/tail -n 1)"
    if [[ -n "$percent" ]]; then
      progress_write "$state_file" "running" "$percent" "Copying to $REMOTE_NAME" "$percent% - $item_count item(s)"
    elif [[ "$line" == *"building file list"* ]]; then
      progress_write "$state_file" "running" "-1" "Copying to $REMOTE_NAME" "Preparing file list..."
    fi
  done
  [[ -f "$cancel_file" ]] && return 130
  return 0
}

terminate_process_tree() {
  local pid="$1" signal="${2:-TERM}" children child
  [[ "$pid" == <-> ]] || return 0
  children="$(/usr/bin/pgrep -P "$pid" 2>/dev/null || true)"
  for child in ${(f)children}; do
    [[ -n "$child" ]] && terminate_process_tree "$child" "$signal"
  done
  /bin/kill "-${signal}" "$pid" >/dev/null 2>&1 || true
}

stop_process_tree() {
  local pid="$1"
  [[ "$pid" == <-> ]] || return 0
  terminate_process_tree "$pid" TERM
  /bin/sleep 1
  if /bin/kill -0 "$pid" >/dev/null 2>&1; then
    terminate_process_tree "$pid" KILL
  fi
}

start_cancel_monitor() {
  local cancel_file="$1" state_file="$2" title="$3"
  shift 3
  local -a watched_pids
  watched_pids=("$@")
  (
    local pid alive
    while true; do
      [[ -f "$cancel_file" ]] && break
      alive=0
      for pid in "${watched_pids[@]}"; do
        if [[ "$pid" == <-> ]] && /bin/kill -0 "$pid" >/dev/null 2>&1; then
          alive=1
          break
        fi
      done
      (( alive == 0 )) && exit 0
      /bin/sleep 0.25
    done
    progress_write "$state_file" "running" "0" "${title} canceled" "Stopping transfer..."
    for pid in "${watched_pids[@]}"; do
      stop_process_tree "$pid"
    done
  ) >/dev/null 2>&1 &
  CANCEL_MONITOR_PID="$!"
}

stop_helper_pid() {
  local pid="$1"
  [[ "$pid" == <-> ]] || return 0
  /bin/kill "$pid" >/dev/null 2>&1 || true
  wait "$pid" 2>/dev/null || true
}

cleanup_remote_transfer_artifacts() {
  local remote_dir_quoted="$1" remote_temp_dir_quoted="${2:-}"
  local cleanup_script
  cleanup_script="cd ${remote_dir_quoted} || exit 0"$'\n'
  if [[ -n "$remote_temp_dir_quoted" ]]; then
    cleanup_script+="/bin/rm -rf ${remote_temp_dir_quoted}"$'\n'
  fi
  cleanup_script+="/bin/rm -rf .open-remote-partials"$'\n'
  /usr/bin/ssh "${SSH_OPTS[@]}" -- "$REMOTE_SSH_ALIAS" \
    "$cleanup_script" \
    >> "$TRANSFER_LOG" 2>&1 || true
}

port_listener_pids() {
  /usr/sbin/lsof -nP -tiTCP:"$LOCAL_PORT" -sTCP:LISTEN 2>/dev/null | /usr/bin/sort -u || true
}

expected_tunnel_pid() {
  local pid command
  for pid in ${(f)"$(port_listener_pids)"}; do
    [[ "$pid" == <-> ]] || continue
    command="$(/bin/ps -p "$pid" -o command= 2>/dev/null || true)"
    if [[ "$command" == *"/usr/bin/ssh"* && "$command" == *"-L ${LOCAL_PORT}:127.0.0.1:5900"* && "$command" == *"-- ${REMOTE_SSH_ALIAS}"* ]]; then
      printf '%s\n' "$pid"
      return 0
    fi
  done
  return 1
}

stop_tunnel_pid() {
  local pid="$1"
  [[ "$pid" == <-> ]] || return 0
  /bin/kill "$pid" >/dev/null 2>&1 || true
  /bin/sleep 1
  /bin/kill -0 "$pid" >/dev/null 2>&1 && /bin/kill -KILL "$pid" >/dev/null 2>&1 || true
}

has_drop_args() {
  local item
  for item in "$@"; do
    [[ "$item" == -psn_* ]] && continue
    return 0
  done
  return 1
}

copy_dropped_items() {
  local item remote_dir_quoted remote_dest rsync_ssh backup_suffix item_count progress_state cancel_file progress_pid
  local rsync_status tr_status updater_status transfer_status_file transfer_pid transfer_wait_status cancel_monitor_pid
  local remote_temp_dir remote_temp_dir_quoted commit_script commit_status source_name_quoted final_name_quoted transfer_name
  local saw_drop_arg=0
  local -a dropped_items transfer_pipe_status rsync_args

  validate_config
  dropped_items=()
  for item in "$@"; do
    [[ "$item" == -psn_* ]] && continue
    saw_drop_arg=1
    [[ "$item" != "/" ]] && item="${item%/}"
    if [[ -e "$item" || -L "$item" ]]; then
      dropped_items+=("$item")
    else
      transfer_log "Ignored missing dropped item: $item"
    fi
  done

  if (( ${#dropped_items[@]} == 0 )); then
    if (( saw_drop_arg == 1 )); then
      alert_user "Remote file transfer failed" "The dropped item could not be found anymore, so nothing was copied."
      exit 1
    fi
    return 1
  fi

  remote_dir_quoted="$(printf '%q' "$REMOTE_DROP_DIR")"
  rsync_ssh=""
  for item in /usr/bin/ssh "${SSH_OPTS[@]}"; do
    rsync_ssh+=" $(printf '%q' "$item")"
  done
  rsync_ssh="${rsync_ssh# }"

  item_count="${#dropped_items[@]}"
  transfer_log "Starting transfer of ${item_count} item(s) to ${REMOTE_NAME}:${REMOTE_DROP_DIR}."
  progress_state="$(/usr/bin/mktemp /tmp/open-remote-transfer-progress.XXXXXX)"
  cancel_file="${progress_state}.cancel"
  progress_write "$progress_state" "running" "-1" "Copying to $REMOTE_NAME" "Preparing ${item_count} item(s)..."
  start_progress_viewer "$progress_state" "Copying to $REMOTE_NAME" "$cancel_file"
  progress_pid="$PROGRESS_VIEWER_PID"
  transfer_status_file="$(/usr/bin/mktemp /tmp/open-remote-transfer-status.XXXXXX)"
  transfer_pid=""
  cancel_monitor_pid=""
  remote_temp_dir=""
  remote_temp_dir_quoted=""

  finish_canceled_transfer() {
    trap - ERR INT TERM HUP
    [[ -n "${cancel_monitor_pid:-}" ]] && stop_helper_pid "$cancel_monitor_pid"
    cancel_monitor_pid=""
    if [[ -n "${transfer_pid:-}" ]]; then
      stop_process_tree "$transfer_pid"
      wait "$transfer_pid" 2>/dev/null || true
      transfer_pid=""
    fi
    cleanup_remote_transfer_artifacts "$remote_dir_quoted" "$remote_temp_dir_quoted"
    remote_temp_dir=""
    remote_temp_dir_quoted=""
    transfer_log "Transfer canceled by user."
    progress_write "$progress_state" "cancelled" "0" "Copy to $REMOTE_NAME canceled" "Stopped and cleaned up"
    cleanup_progress_state_later "$progress_state" "$cancel_file"
    /bin/rm -f "$transfer_status_file" >/dev/null 2>&1 || true
    notify_user "Remote File Transfer" "Canceled copy to ${REMOTE_NAME}."
    exit 130
  }

  transfer_failed_unexpected() {
    local status="$?"
    trap - ERR INT TERM HUP
    [[ -n "${cancel_monitor_pid:-}" ]] && stop_helper_pid "$cancel_monitor_pid"
    cancel_monitor_pid=""
    if [[ -n "${transfer_pid:-}" ]]; then
      stop_process_tree "$transfer_pid"
      wait "$transfer_pid" 2>/dev/null || true
      transfer_pid=""
    fi
    cleanup_remote_transfer_artifacts "$remote_dir_quoted" "$remote_temp_dir_quoted"
    remote_temp_dir=""
    remote_temp_dir_quoted=""
    transfer_log "Transfer stopped unexpectedly with status ${status}."
    progress_write "$progress_state" "error" "0" "Copy to $REMOTE_NAME failed" "Transfer stopped unexpectedly" || true
    cleanup_progress_state_later "$progress_state" "$cancel_file" || true
    /bin/rm -f "$transfer_status_file" >/dev/null 2>&1 || true
    exit "$status"
  }

  transfer_interrupted() {
    trap - ERR INT TERM HUP
    [[ -n "${cancel_monitor_pid:-}" ]] && stop_helper_pid "$cancel_monitor_pid"
    cancel_monitor_pid=""
    if [[ -n "${transfer_pid:-}" ]]; then
      stop_process_tree "$transfer_pid"
      wait "$transfer_pid" 2>/dev/null || true
      transfer_pid=""
    fi
    cleanup_remote_transfer_artifacts "$remote_dir_quoted" "$remote_temp_dir_quoted"
    remote_temp_dir=""
    remote_temp_dir_quoted=""
    transfer_log "Transfer interrupted."
    progress_write "$progress_state" "cancelled" "0" "Copy to $REMOTE_NAME interrupted" "Stopped and cleaned up" || true
    cleanup_progress_state_later "$progress_state" "$cancel_file" || true
    /bin/rm -f "$transfer_status_file" >/dev/null 2>&1 || true
    exit 143
  }

  trap transfer_failed_unexpected ERR
  trap transfer_interrupted INT TERM HUP

  /usr/bin/ssh "${SSH_OPTS[@]}" -- "$REMOTE_SSH_ALIAS" "mkdir -p ${remote_dir_quoted}" >> "$TRANSFER_LOG" 2>&1 || {
    progress_write "$progress_state" "error" "0" "Copy to $REMOTE_NAME failed" "Could not create ${REMOTE_DROP_DIR}"
    cleanup_progress_state_later "$progress_state" "$cancel_file"
    /bin/rm -f "$transfer_status_file" >/dev/null 2>&1 || true
    alert_user "Remote file transfer failed" "Could not create ${REMOTE_DROP_DIR} on ${REMOTE_NAME}."
    exit 1
  }
  [[ -f "$cancel_file" ]] && finish_canceled_transfer

  remote_temp_dir="$(/usr/bin/ssh "${SSH_OPTS[@]}" -- "$REMOTE_SSH_ALIAS" \
    "cd ${remote_dir_quoted} && /usr/bin/mktemp -d .open-remote-transfer.XXXXXX" 2>> "$TRANSFER_LOG")"
  if [[ -z "$remote_temp_dir" || "$remote_temp_dir" != .open-remote-transfer.* || "$remote_temp_dir" == */* ]]; then
    progress_write "$progress_state" "error" "0" "Copy to $REMOTE_NAME failed" "Could not prepare temporary destination"
    cleanup_progress_state_later "$progress_state" "$cancel_file"
    /bin/rm -f "$transfer_status_file" >/dev/null 2>&1 || true
    alert_user "Remote file transfer failed" "Could not prepare a temporary destination on ${REMOTE_NAME}."
    exit 1
  fi
  remote_temp_dir_quoted="$(printf '%q' "$remote_temp_dir")"
  remote_dest="${REMOTE_SSH_ALIAS}:${remote_dir_quoted}/${remote_temp_dir_quoted}/"
  [[ -f "$cancel_file" ]] && finish_canceled_transfer

  backup_suffix=".before-remote-drop-$(/bin/date +%Y%m%d-%H%M%S)-$$"
  rsync_args=(
    -aE
    --progress
    --delay-updates
    --partial
    --partial-dir=.open-remote-partials
    --backup
    --suffix="$backup_suffix"
    --timeout=120
    --contimeout=15
  )
  [[ "$RSYNC_WHOLE_FILE" == "1" ]] && rsync_args+=(-W)

  set +e
  (
    set +e
    /usr/bin/rsync \
      "${rsync_args[@]}" \
      -e "$rsync_ssh" \
      -- \
      "${dropped_items[@]}" \
      "$remote_dest" 2>&1 | /usr/bin/tr '\r' '\n' | update_rsync_progress "$progress_state" "$cancel_file" "$item_count"
    transfer_pipe_status=("${pipestatus[@]}")
    printf '%s %s %s\n' "${transfer_pipe_status[1]:-125}" "${transfer_pipe_status[2]:-125}" "${transfer_pipe_status[3]:-125}" > "$transfer_status_file"
    if [[ -f "$cancel_file" || "${transfer_pipe_status[3]:-0}" == "130" ]]; then
      exit 130
    fi
    exit "${transfer_pipe_status[1]:-125}"
  ) &
  transfer_pid="$!"
  start_cancel_monitor "$cancel_file" "$progress_state" "Copy to $REMOTE_NAME" "$transfer_pid"
  cancel_monitor_pid="$CANCEL_MONITOR_PID"
  wait "$transfer_pid"
  transfer_wait_status="$?"
  transfer_pid=""
  set -e
  [[ -n "${cancel_monitor_pid:-}" ]] && stop_helper_pid "$cancel_monitor_pid"
  cancel_monitor_pid=""

  if [[ -f "$transfer_status_file" ]]; then
    read -r rsync_status tr_status updater_status < "$transfer_status_file" || true
  else
    rsync_status="$transfer_wait_status"
    tr_status=125
    updater_status=125
  fi
  /bin/rm -f "$transfer_status_file" >/dev/null 2>&1 || true
  transfer_log "Transfer statuses: rsync=${rsync_status} tr=${tr_status} progress=${updater_status} wait=${transfer_wait_status}."

  if [[ -f "$cancel_file" || "$transfer_wait_status" == "130" || "$updater_status" == "130" ]]; then
    finish_canceled_transfer
  fi

  if [[ "$rsync_status" == "0" ]]; then
    [[ -f "$cancel_file" ]] && finish_canceled_transfer
    backup_suffix=".from-local-$(/bin/date +%Y%m%d-%H%M%S)-$$"
    commit_script="cd ${remote_dir_quoted} || exit 1"$'\n'
    for item in "${dropped_items[@]}"; do
      transfer_name="$(/usr/bin/basename -- "$item")"
      source_name_quoted="$(printf '%q' "./${remote_temp_dir}/${transfer_name}")"
      final_name_quoted="$(printf '%q' "./${transfer_name}")"
      commit_script+="source=${source_name_quoted}"$'\n'
      commit_script+="final=${final_name_quoted}"$'\n'
      commit_script+="if [ -e \"\$final\" ]; then i=0; while :; do if [ \"\$i\" -eq 0 ]; then candidate=\"\${final}${backup_suffix}\"; else candidate=\"\${final}${backup_suffix}-\$i\"; fi; if [ ! -e \"\$candidate\" ]; then final=\"\$candidate\"; break; fi; i=\$((i + 1)); done; fi"$'\n'
      commit_script+="/bin/mv -n \"\$source\" \"\$final\" || exit \$?"$'\n'
      commit_script+="if [ -e \"\$source\" ]; then exit 73; fi"$'\n'
      commit_script+="/usr/bin/touch -m \"\$final\" 2>/dev/null || true"$'\n'
    done
    commit_script+="/bin/rm -rf ${remote_temp_dir_quoted} || exit \$?"$'\n'

    set +e
    /usr/bin/ssh "${SSH_OPTS[@]}" -- "$REMOTE_SSH_ALIAS" "$commit_script" >> "$TRANSFER_LOG" 2>&1
    commit_status="$?"
    set -e

    if [[ "$commit_status" != "0" ]]; then
      transfer_log "Transfer commit failed with status ${commit_status}."
      cleanup_remote_transfer_artifacts "$remote_dir_quoted" "$remote_temp_dir_quoted"
      remote_temp_dir=""
      remote_temp_dir_quoted=""
      progress_write "$progress_state" "error" "0" "Copy to $REMOTE_NAME failed" "Could not finalize copied item(s)"
      cleanup_progress_state_later "$progress_state" "$cancel_file"
      alert_user "Remote file transfer failed" "The file stream arrived, but copied item(s) could not be finalized on ${REMOTE_NAME}. See ${TRANSFER_LOG} for details."
      exit 1
    fi

    remote_temp_dir=""
    remote_temp_dir_quoted=""
    transfer_log "Transfer complete."
    progress_write "$progress_state" "done" "100" "Copied to $REMOTE_NAME" "Done - ${item_count} item(s)"
    cleanup_progress_state_later "$progress_state" "$cancel_file"
    notify_user "Remote File Transfer" "Copied ${item_count} item(s) to ${REMOTE_NAME}:~/${REMOTE_DROP_DIR}"
    exit 0
  fi

  transfer_log "Transfer failed."
  cleanup_remote_transfer_artifacts "$remote_dir_quoted" "$remote_temp_dir_quoted"
  remote_temp_dir=""
  remote_temp_dir_quoted=""
  progress_write "$progress_state" "error" "0" "Copy to $REMOTE_NAME failed" "See file-transfer.log"
  cleanup_progress_state_later "$progress_state" "$cancel_file"
  alert_user "Remote file transfer failed" "Could not copy the dropped item(s) to ${REMOTE_NAME}:~/${REMOTE_DROP_DIR}. See ${TRANSFER_LOG} for details."
  exit 1
}

if has_drop_args "$@"; then
  copy_dropped_items "$@"
fi

validate_config
launcher_log "Launcher started."
if [[ "$SHOW_OPEN_NOTIFICATION" == "1" ]]; then
  if [[ "$USE_SSH_TUNNEL" == "1" ]]; then
    notify_user "$APP_NAME" "Opening ${REMOTE_NAME} through a protected SSH tunnel."
  else
    notify_user "$APP_NAME" "Opening ${REMOTE_NAME} directly in Screen Sharing."
  fi
fi

cleanup() {
  if [[ "$ENABLE_MIC" == "1" && -x "$MIC_CONTROL" ]] && (( MIC_WAS_RUNNING == 0 )); then
    launcher_log "Stopping mic supervisor started by this launcher."
    "$MIC_CONTROL" stop >/dev/null 2>&1 || true
  fi
  if (( TUNNEL_OWNER == 1 )); then
    launcher_log "Closing SSH tunnel created by this launcher."
    if [[ -n "${TUNNEL_PID:-}" ]]; then
      stop_tunnel_pid "$TUNNEL_PID"
    else
      /usr/bin/ssh -S "$CONTROL_SOCKET" -O exit "${SSH_OPTS[@]}" -- "$REMOTE_SSH_ALIAS" >/dev/null 2>&1 || true
    fi
    /bin/rm -f "$CONTROL_SOCKET" >/dev/null 2>&1 || true
  elif [[ "$USE_SSH_TUNNEL" == "1" ]]; then
    launcher_log "Leaving reused SSH tunnel untouched."
  else
    launcher_log "No Screen Sharing SSH tunnel to clean up."
  fi
}

on_signal() {
  cleanup
  exit 143
}

trap cleanup EXIT
trap on_signal INT TERM HUP

if [[ "$ENABLE_MIC" == "1" ]]; then
  if [[ ! -x "$MIC_CONTROL" ]]; then
    notify_user "$APP_NAME" "Remote mic helper is not installed; opening desktop only."
  elif "$MIC_CONTROL" is-running >/dev/null 2>&1; then
    MIC_WAS_RUNNING=1
    launcher_log "Remote mic supervisor was already running before this launch."
  fi
fi

OPEN_VNC_HOST="$REMOTE_VNC_HOST"
OPEN_VNC_PORT="$REMOTE_VNC_PORT"

if [[ "$USE_SSH_TUNNEL" == "1" ]]; then
  existing_tunnel_pid="$(expected_tunnel_pid || true)"
  if [[ -n "$existing_tunnel_pid" ]]; then
    launcher_log "Found existing SSH tunnel pid ${existing_tunnel_pid} on local port ${LOCAL_PORT}; reusing it without ownership."
  elif [[ -n "$(port_listener_pids)" ]]; then
    launcher_log "Local port ${LOCAL_PORT} is busy and is not the expected SSH tunnel."
    alert_user "Remote Desktop port is busy" "Local port ${LOCAL_PORT} is already in use by another process."
    exit 1
  fi

  existing_tunnel_pid="$(expected_tunnel_pid || true)"
  if [[ -n "$existing_tunnel_pid" ]]; then
    launcher_log "SSH tunnel already active as pid ${existing_tunnel_pid}; reusing it without ownership."
  else
    if /usr/bin/ssh -S "$CONTROL_SOCKET" -O check "${SSH_OPTS[@]}" -- "$REMOTE_SSH_ALIAS" >/dev/null 2>&1; then
      launcher_log "Found stale SSH control master without local listener; closing it before creating a fresh tunnel."
      /usr/bin/ssh -S "$CONTROL_SOCKET" -O exit "${SSH_OPTS[@]}" -- "$REMOTE_SSH_ALIAS" >/dev/null 2>&1 || true
    fi
    /bin/rm -f "$CONTROL_SOCKET" >/dev/null 2>&1 || true

    launcher_log "Creating SSH tunnel localhost:${LOCAL_PORT} -> ${REMOTE_NAME}:5900."
    tunnel_output="$(/usr/bin/ssh -fN \
      -o ExitOnForwardFailure=yes \
      "${SSH_OPTS[@]}" \
      -L "${LOCAL_PORT}:127.0.0.1:5900" \
      -- "$REMOTE_SSH_ALIAS" 2>&1)" || {
      launcher_log "SSH tunnel creation failed: ${tunnel_output}"
      alert_user "Remote Desktop tunnel failed" "Could not create the SSH tunnel to ${REMOTE_NAME}. Check the network/VPN and try again."
      exit 1
    }
    TUNNEL_OWNER=1
    for _ in {1..20}; do
      TUNNEL_PID="$(expected_tunnel_pid || true)"
      [[ -n "$TUNNEL_PID" ]] && break
      /bin/sleep 0.25
    done
    if [[ -z "$TUNNEL_PID" ]]; then
      launcher_log "SSH tunnel command succeeded, but no expected listener appeared on local port ${LOCAL_PORT}."
      alert_user "Remote Desktop tunnel failed" "The SSH tunnel started but did not become reachable on localhost:${LOCAL_PORT}."
      exit 1
    fi
    launcher_log "Created SSH tunnel pid ${TUNNEL_PID} on local port ${LOCAL_PORT}."
  fi

  if ! /usr/bin/nc -G 5 -z localhost "$LOCAL_PORT" >/dev/null 2>&1; then
    launcher_log "Local VNC tunnel port ${LOCAL_PORT} did not become reachable."
    alert_user "Remote Desktop unavailable" "Could not reach ${REMOTE_NAME} over SSH. Check the network/VPN and try again."
    exit 1
  fi

  OPEN_VNC_HOST="localhost"
  OPEN_VNC_PORT="$LOCAL_PORT"
  launcher_log "Opening Screen Sharing via SSH tunnel localhost:${LOCAL_PORT}."
else
  launcher_log "Opening Screen Sharing directly via ${REMOTE_VNC_HOST}:${REMOTE_VNC_PORT}; no SSH tunnel for video."
fi

/usr/bin/open -a "Screen Sharing" "vnc://${REMOTE_USER}@${OPEN_VNC_HOST}:${OPEN_VNC_PORT}?${VNC_OPTIONS}"

if [[ "$ENABLE_MIC" == "1" && -x "$MIC_CONTROL" ]]; then
  launcher_log "Starting foreground mic supervisor."
  /usr/bin/env \
    LOCAL_VNC_PORT="$LOCAL_VNC_PORT" \
    VNC_MATCH_HOST="$VNC_MATCH_HOST" \
    "$MIC_CONTROL" start-foreground >> "$MIC_LOG" 2>&1
  launcher_log "Foreground mic supervisor exited."
else
  launcher_log "Mic supervisor disabled or missing; leaving tunnel open until app exits."
  while /usr/bin/pgrep -x "Screen Sharing" >/dev/null 2>&1; do
    /bin/sleep 5
  done
fi
